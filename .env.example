RUSTFS_ACCESS_KEY=login-s3-admin
RUSTFS_SECRET_KEY=replace-with-a-long-random-secret
RUSTFS_SERVER_DOMAINS=s3.login.no

AUTHENTIK_URL=https://authentik.login.no
AUTHENTIK_APPLICATION_SLUG=s3
AUTHENTIK_ALLOWED_GROUP=s3
AUTHENTIK_API_TOKEN=replace-with-authentik-api-token

RUSTFS_IDENTITY_OPENID_ENABLE=on
RUSTFS_IDENTITY_OPENID_CONFIG_URL=https://authentik.login.no/application/o/s3/
RUSTFS_IDENTITY_OPENID_CLIENT_ID=replace-with-authentik-client-id
RUSTFS_IDENTITY_OPENID_CLIENT_SECRET=replace-with-authentik-client-secret
RUSTFS_IDENTITY_OPENID_SCOPES=openid,profile,email
RUSTFS_IDENTITY_OPENID_REDIRECT_URI=https://spaces.login.no/rustfs/admin/v3/oidc/callback/default
RUSTFS_IDENTITY_OPENID_REDIRECT_URI_DYNAMIC=off
RUSTFS_IDENTITY_OPENID_CLAIM_NAME=groups
RUSTFS_IDENTITY_OPENID_GROUPS_CLAIM=groups
RUSTFS_IDENTITY_OPENID_ROLE_POLICY=readwrite
RUSTFS_IDENTITY_OPENID_DISPLAY_NAME=Authentik
